{
  "name": "nexus-state",
  "version": "4.0.0",
  "description": "Lightweight, traceable global state manager for JavaScript and React.",
  "author": "Georg Schilin",
  "license": "MIT",
  "type": "module",
  "private": true,
  "main": "./dist/cjs/index.js",
  "module": "./dist/esm/index.js",
  "types": "./dist/esm/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/esm/index.d.ts",
        "default": "./dist/esm/index.js"
      },
      "require": {
        "types": "./dist/cjs/index.d.cts",
        "default": "./dist/cjs/index.js"
      }
    },
    "./react": {
      "import": {
        "types": "./dist/esm/react.d.ts",
        "default": "./dist/esm/react.js"
      },
      "require": {
        "types": "./dist/cjs/react.d.cts",
        "default": "./dist/cjs/react.js"
      }
    },
    "./devtools": {
      "import": {
        "types": "./dist/esm/devtools.d.ts",
        "default": "./dist/esm/devtools.js"
      },
      "require": {
        "types": "./dist/cjs/devtools.d.cts",
        "default": "./dist/cjs/devtools.js"
      }
    },
    "./computed": {
      "import": {
        "types": "./dist/esm/computed.d.ts",
        "default": "./dist/esm/computed.js"
      },
      "require": {
        "types": "./dist/cjs/computed.d.cts",
        "default": "./dist/cjs/computed.js"
      }
    },
    "./package.json": "./package.json"
  },
  "typesVersions": {
    "*": {
      "react": [
        "./dist/esm/react.d.ts"
      ],
      "devtools": [
        "./dist/esm/devtools.d.ts"
      ],
      "computed": [
        "./dist/esm/computed.d.ts"
      ]
    }
  },
  "sideEffects": false,
  "engines": {
    "node": ">=12.20"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "lint": "eslint src",
    "typecheck": "tsc -p tsconfig.check.json",
    "test": "vitest run",
    "test:watch": "vitest",
    "build": "rollup -c && node scripts/write-markers.mjs",
    "package-prepare": "npm run typecheck && npm run test && npm run build && node scripts/prepare-publish.mjs",
    "publish:dry": "npm run package-prepare && npm publish ./publish --dry-run",
    "publish": "npm run package-prepare && npm publish ./publish --access public",
    "npm-login": "npm login"
  },
  "keywords": [
    "react",
    "action",
    "state manager",
    "global state",
    "state store",
    "middleware",
    "persist"
  ],
  "peerDependencies": {
    "react": ">=16.8 <20"
  },
  "peerDependenciesMeta": {
    "react": {
      "optional": true
    }
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/voodoofugu/nexus-state.git"
  },
  "devDependencies": {
    "@eslint/js": "^9.17.0",
    "@rollup/plugin-commonjs": "^28.0.0",
    "@rollup/plugin-node-resolve": "^15.2.3",
    "@rollup/plugin-terser": "^0.4.4",
    "@rollup/plugin-typescript": "^11.1.6",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^24.0.7",
    "@types/react": "^18.3.7",
    "@types/react-dom": "^18.3.7",
    "eslint": "^9.17.0",
    "eslint-plugin-react": "^7.37.2",
    "globals": "^15.13.0",
    "jsdom": "^29.1.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "rollup": "^4.21.3",
    "rollup-plugin-delete": "^2.1.0",
    "rollup-plugin-dts": "^6.4.1",
    "tslib": "^2.7.0",
    "typescript": "^5.6.2",
    "typescript-eslint": "^8.18.0",
    "vitest": "^2.1.9"
  }
}
