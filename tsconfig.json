{
  "compilerOptions": {
    "module": "ESNext",
    "target": "es5",
    "lib": ["dom", "es2019"],
    "esModuleInterop": true,
    "moduleResolution": "node",
    "types": ["react", "node"],
    "typeRoots": ["./node_modules/@types"],
    "strict": true,
    "declaration": false,
    "downlevelIteration": true,
    "jsx": "react-jsx",
    "skipLibCheck": true
  },
  "include": ["src"],
  "exclude": ["node_modules", "dist"]
}
